{
  "name": "@pwv/agentcribs",
  "version": "1.0.0",
  "description": "AgentCribs — a curated PWV community for agentic software builders",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "none",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "deploy:staging": "npm run clean && npm run build && wrangler deploy --env staging",
    "deploy:production": "npm run clean && npm run build && wrangler deploy --env production",
    "generate": "rw-scripts ensure-env",
    "check": "npm run generate && npm run types",
    "types": "tsc",
    "migrate:new": "drizzle-kit generate",
    "migrate:dev": "wrangler d1 migrations apply DB --local",
    "migrate:prod": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "@c15t/dev-tools": "^2.0.1",
    "@c15t/react": "^2.0.3",
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/dm-mono": "^5.2.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "ai": "^6.0.169",
    "ai-gateway-provider": "^3.1.3",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "marked": "^18.0.3",
    "nanoid": "^5.1.11",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-email": "6.0.5",
    "react-server-dom-webpack": "19.2.6",
    "rwsdk": "1.2.5",
    "tailwindcss": "^4.2.4",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.33.2",
    "@cloudflare/vitest-pool-workers": "^0.16.5",
    "@cloudflare/workers-types": "4.20260426.1",
    "@content-collections/core": "^0.15.0",
    "@content-collections/markdown": "^0.1.4",
    "@content-collections/vite": "^0.3.0",
    "@react-email/ui": "6.0.5",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.31.10",
    "rwsdk-community": "^0.1.2",
    "typescript": "6.0.3",
    "vite": "~7.3.2",
    "vitest": "^4.1.6",
    "wrangler": "4.85.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
