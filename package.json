{
  "name": "@pwv/agentcribs",
  "version": "1.0.0",
  "description": "AgentCribs — a curated PWV community for agentic software builders",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "none",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@fontsource/dm-mono": "^5.2.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-server-dom-webpack": "19.2.5",
    "rwsdk": "1.2.5",
    "tailwindcss": "^4.2.4",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.33.2",
    "@cloudflare/workers-types": "4.20260426.1",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "vite": "~7.3.2",
    "wrangler": "4.85.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
