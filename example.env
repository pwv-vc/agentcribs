# Local dev — defaults for `pnpm dev`
ADMIN_PASSWORD: "admin"
ADMIN_COOKIE_NAME: "agentcribs_dev_admin_session"
GITHUB_CLIENT_ID: "your-github-oauth-client-id"
GITHUB_CLIENT_SECRET: "your-github-oauth-client-secret"
GITHUB_CALLBACK_URL: "http://localhost:5173/apply/github/callback"
SEND_EMAIL_FROM: "agentcribs@agentcribs.com"
APP_URL: "http://localhost:5173"
CLOUDFLARE_ACCOUNT_ID: ""
AI_GATEWAY_NAME: ""
CF_AIG_TOKEN: ""

# Deploy with: `pnpm run deploy:staging`
# Secrets must be set per-env:
#   wrangler secret put <KEY> --env staging
# [staging]
# GITHUB_CALLBACK_URL: "https://staging.agentcribs.com/apply/github/callback"
# APP_URL: "https://staging.agentcribs.com"

# Deploy with: `pnpm run deploy:production`
# Secrets must be set per-env:
#   wrangler secret put <KEY> --env production
# [production]
# GITHUB_CALLBACK_URL: "https://agentcribs.com/apply/github/callback"
# APP_URL: "https://agentcribs.com"
