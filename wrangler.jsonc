{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentcribs",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "secrets": {
    "required": [
      "ADMIN_PASSWORD",
      "ADMIN_COOKIE_NAME",
      "GITHUB_CLIENT_ID",
      "GITHUB_CLIENT_SECRET",
      "GITHUB_CALLBACK_URL",
      "SEND_EMAIL_FROM",
      "APP_URL",
    ],
  },
  // ---- Environments ----
  "env": {
    "production": {
      "routes": [
        {
          "pattern": "agentcribs.com",
          "custom_domain": true,
        },
        {
          "pattern": "*.agentcribs.com",
          "custom_domain": true,
        },
      ],
      "r2_buckets": [
        {
          "bucket_name": "agentcribs-applications",
          "binding": "AGENTCRIBS_R2",
        },
      ],
      "kv_namespaces": [
        {
          "binding": "AGENTCRIBS_KV",
          "id": "ba9c5eeaa10b4ce89ec84362d4510cd2",
        },
      ],
      "send_email": [
        {
          "name": "SEND_EMAIL",
        },
      ],
    },
    "staging": {
      "routes": [
        {
          "pattern": "staging.agentcribs.com",
          "custom_domain": true,
        },
      ],
      "r2_buckets": [
        {
          "bucket_name": "agentcribs-applications",
          "binding": "AGENTCRIBS_R2",
        },
      ],
      "kv_namespaces": [
        {
          "binding": "AGENTCRIBS_KV",
          "id": "ba9c5eeaa10b4ce89ec84362d4510cd2",
        },
      ],
      "send_email": [
        {
          "name": "SEND_EMAIL",
        },
      ],
    },
  },
}
