{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "agentcribs",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "ai": {
    "binding": "AI",
  },
  "r2_buckets": [
    {
      "bucket_name": "agentcribs-applications",
      "binding": "AGENTCRIBS_R2",
    },
  ],
  "kv_namespaces": [
    {
      "binding": "AGENTCRIBS_KV",
      "id": "ba9c5eeaa10b4ce89ec84362d4510cd2",
    },
  ],
  "send_email": [
    {
      "name": "SEND_EMAIL",
    },
  ],
  "queues": {
    "producers": [
      {
        "binding": "PROCESS_APPLICATION_QUEUE",
        "queue": "agentcribs-process-application",
      },
      {
        "binding": "SEND_EMAIL_QUEUE",
        "queue": "agentcribs-send-email",
      },
      {
        "binding": "NOTIFICATION_QUEUE",
        "queue": "agentcribs-notifications",
      },
      {
        "binding": "SLACK_QUEUE",
        "queue": "agentcribs-slack",
      },
    ],
    "consumers": [
      {
        "queue": "agentcribs-process-application",
        "max_batch_size": 5,
        "max_batch_timeout": 5,
      },
      {
        "queue": "agentcribs-send-email",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
      },
      {
        "queue": "agentcribs-notifications",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
      },
      {
        "queue": "agentcribs-slack",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
      },
    ],
  },
  "secrets": {
    "required": [
      "ADMIN_PASSWORD",
      "ADMIN_COOKIE_NAME",
      "GITHUB_CLIENT_ID",
      "GITHUB_CLIENT_SECRET",
      "GITHUB_CALLBACK_URL",
      "SEND_EMAIL_FROM",
      "APP_URL",
      "SLACK_WEBHOOK_URL",
      "CLOUDFLARE_ACCOUNT_ID",
      "AI_GATEWAY_NAME",
      "CF_AIG_TOKEN",
    ],
  },
  // ---- Environments ----
  "env": {
    "production": {
      "routes": [
        {
          "pattern": "agentcribs.com",
          "custom_domain": true,
        },
        {
          "pattern": "*.agentcribs.com",
          "custom_domain": true,
        },
      ],
    },
    "staging": {
      "routes": [
        {
          "pattern": "staging.agentcribs.com",
          "custom_domain": true,
        },
      ],
    },
  },
}
